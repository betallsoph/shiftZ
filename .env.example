# shiftZ local development template
#
# Production uses deploy/gcp/shiftz.env.example. Copy this file to .env only
# for local development, then chmod 600 .env. Never commit populated secrets.

# Local Postgres started by compose.local.yml.
DATABASE_URL='postgres://shiftbot:shiftbot@localhost:5432/shiftbot?sslmode=disable'

# Optional migration target. Local Postgres can use DATABASE_URL instead.
MIGRATION_DATABASE_URL='postgres://shiftbot:shiftbot@localhost:5432/shiftbot?sslmode=disable'

SESSION_SECRET=''
TELEGRAM_BOT_TOKEN=''
TELEGRAM_WEBHOOK_SECRET=''

LLM_PROVIDER=gemini
LLM_API_KEY=''
LLM_MODEL=gemini-3.5-flash

APP_ADDR=127.0.0.1:8080
COOKIE_SECURE=false
REMINDER_MODE=disabled
REMINDER_TICK_INTERVAL=1m

DEV_API_ENABLED=false
OWNER_SIGNUP_ENABLED=false
ENT_DEBUG=false

DB_MAX_OPEN_CONNS=5
DB_MAX_IDLE_CONNS=2
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m
