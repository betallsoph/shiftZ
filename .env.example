# shiftZ VPS production template
#
# Copy to .env in the cloned VPS repository, fill every required value,
# then run: chmod 600 .env
# Never commit the populated production file.

# Neon pooled URL for the running app.
DATABASE_URL=''

# Neon direct, non-pooler URL used by the Compose migration service.
MIGRATION_DATABASE_URL=''

SESSION_SECRET=''
TELEGRAM_BOT_TOKEN=''
TELEGRAM_WEBHOOK_SECRET=''

LLM_PROVIDER=gemini
LLM_API_KEY=''
LLM_MODEL=gemini-3.5-flash

APP_ADDR=:8088
COOKIE_SECURE=true
REMINDER_MODE=loop
REMINDER_TICK_INTERVAL=1m

DEV_API_ENABLED=false
OWNER_SIGNUP_ENABLED=false
ENT_DEBUG=false

# Platform admin portal (disabled by default).
ADMIN_PORTAL_ENABLED=false
# ADMIN_USERNAME=
# ADMIN_PASSWORD=
# ADMIN_SESSION_SECRET=  # openssl rand -base64 32

DB_MAX_OPEN_CONNS=5
DB_MAX_IDLE_CONNS=2
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m
