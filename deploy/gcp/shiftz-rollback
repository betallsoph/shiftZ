#!/usr/bin/env bash
set -Eeuo pipefail

readonly SERVICE="shiftz.service"
readonly APP_DIR="/opt/shiftz"
readonly APP="$APP_DIR/shiftz"
readonly PREVIOUS="$APP_DIR/shiftz.previous"
readonly NEXT="$APP_DIR/shiftz.rollback.next"
readonly CURRENT_COPY="$APP_DIR/shiftz.current.next"
readonly LOCK="/run/lock/shiftz-deploy.lock"

health_check() {
  for _ in {1..40}; do
    if curl -fsS --max-time 3 http://127.0.0.1:8088/livez >/dev/null 2>&1 && \
      curl -fsS --max-time 5 http://127.0.0.1:8088/readyz >/dev/null 2>&1; then
      return 0
    fi
    sleep 2
  done
  return 1
}

exec 9>"$LOCK"
flock -n 9 || {
  echo "Another shiftZ deployment is already running." >&2
  exit 3
}

trap 'rm -f "$NEXT" "$CURRENT_COPY"' EXIT

if [[ ! -f "$PREVIOUS" ]]; then
  echo "No previous binary is available." >&2
  exit 4
fi

install -o root -g shiftz -m 0750 "$PREVIOUS" "$NEXT"
if [[ -f "$APP" ]]; then
  install -o root -g shiftz -m 0750 "$APP" "$CURRENT_COPY"
fi
mv -f "$NEXT" "$APP"
if [[ -f "$CURRENT_COPY" ]]; then
  mv -f "$CURRENT_COPY" "$PREVIOUS"
fi

systemctl restart "$SERVICE"
if health_check; then
  echo "Manual rollback is healthy."
  exit 0
fi

echo "Rolled-back binary failed health checks; restoring original binary." >&2
if [[ -f "$PREVIOUS" ]]; then
  install -o root -g shiftz -m 0750 "$PREVIOUS" "$NEXT"
  mv -f "$NEXT" "$APP"
  systemctl restart "$SERVICE"
  if health_check; then
    echo "Original binary is healthy again; rollback remains failed." >&2
    exit 5
  fi
fi

echo "Original binary also failed health checks." >&2
systemctl --no-pager --full status "$SERVICE" >&2 || true
journalctl -u "$SERVICE" -n 60 --no-pager >&2 || true
exit 6
