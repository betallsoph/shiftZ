#!/usr/bin/env bash
set -Eeuo pipefail

readonly SERVICE="shiftz.service"
readonly APP_DIR="/opt/shiftz"
readonly APP="$APP_DIR/shiftz"
readonly PREVIOUS="$APP_DIR/shiftz.previous"
readonly NEXT="$APP_DIR/shiftz.next"
readonly LOCK="/run/lock/shiftz-deploy.lock"

log() {
  printf '==> %s\n' "$*"
}

health_check() {
  for _ in {1..40}; do
    if curl --fail --silent --show-error --max-time 3 \
      http://127.0.0.1:8088/livez >/dev/null 2>&1 && \
      curl --fail --silent --show-error --max-time 5 \
      http://127.0.0.1:8088/readyz >/dev/null 2>&1; then
      return 0
    fi
    sleep 2
  done
  return 1
}

if [[ -z "${SUDO_USER:-}" || "$SUDO_USER" == "root" ]]; then
  echo "Run this script through sudo as the deployment user." >&2
  exit 2
fi

deploy_home="$(getent passwd "$SUDO_USER" | cut -d: -f6)"
readonly STAGED="$deploy_home/shiftz.new"

exec 9>"$LOCK"
if ! flock -n 9; then
  echo "Another shiftZ deployment is already running." >&2
  exit 3
fi

trap 'rm -f "$NEXT" "$STAGED"' EXIT

if [[ ! -f "$STAGED" || ! -x "$STAGED" || -L "$STAGED" ]]; then
  echo "Missing regular executable staged binary: $STAGED" >&2
  exit 4
fi

if [[ "$(stat -c '%U' "$STAGED")" != "$SUDO_USER" ]]; then
  echo "Staged binary must be owned by deployment user $SUDO_USER." >&2
  exit 4
fi

if ! file -b "$STAGED" | grep -Eq 'ELF 64-bit.*x86-64'; then
  echo "Staged artifact is not a Linux amd64 ELF binary." >&2
  file -b "$STAGED" >&2 || true
  exit 5
fi

log "Installing staged binary"
install -o root -g shiftz -m 0750 "$STAGED" "$NEXT"

had_previous=false
if [[ -f "$APP" ]]; then
  had_previous=true
  previous_tmp="$APP_DIR/shiftz.previous.next"
  install -o root -g shiftz -m 0750 "$APP" "$previous_tmp"
  mv -f "$previous_tmp" "$PREVIOUS"
fi

mv -f "$NEXT" "$APP"
systemctl restart "$SERVICE"

log "Waiting for liveness and readiness"
if health_check; then
  log "Deployment is healthy"
  systemctl --no-pager --full status "$SERVICE" | sed -n '1,12p'
  exit 0
fi

echo "New binary failed health checks." >&2
systemctl --no-pager --full status "$SERVICE" >&2 || true
journalctl -u "$SERVICE" -n 60 --no-pager >&2 || true

if [[ "$had_previous" != true || ! -f "$PREVIOUS" ]]; then
  echo "No previous binary exists; stopping failed first deployment." >&2
  systemctl stop "$SERVICE" || true
  exit 6
fi

log "Restoring previous binary"
install -o root -g shiftz -m 0750 "$PREVIOUS" "$NEXT"
mv -f "$NEXT" "$APP"
systemctl restart "$SERVICE"

if health_check; then
  echo "Rollback succeeded; deployment remains failed." >&2
  exit 7
fi

echo "Rollback also failed. Manual intervention is required." >&2
systemctl --no-pager --full status "$SERVICE" >&2 || true
journalctl -u "$SERVICE" -n 60 --no-pager >&2 || true
exit 8
