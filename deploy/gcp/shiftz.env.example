# Runtime settings for /etc/shiftz/shiftz.env.
# Keep this file root-owned with mode 600. Never place the Neon direct
# migration URL here; GitHub Actions owns MIGRATION_DATABASE_URL.

APP_ADDR=127.0.0.1:8088
DATABASE_URL='Neon pooled URL'

SESSION_SECRET='generate with: openssl rand -base64 32'
COOKIE_SECURE=true

TELEGRAM_BOT_TOKEN='BotFather token'
TELEGRAM_WEBHOOK_SECRET='generate with: openssl rand -hex 32'

LLM_PROVIDER=gemini
LLM_API_KEY='Google AI Studio API key'
LLM_MODEL=gemini-3.5-flash

REMINDER_MODE=loop
REMINDER_TICK_INTERVAL=1m

DEV_API_ENABLED=false
OWNER_SIGNUP_ENABLED=false
ENT_DEBUG=false

DB_MAX_OPEN_CONNS=5
DB_MAX_IDLE_CONNS=2
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m
